package br.eejk.banco.model;

// Classe base para Conta Corrente e Conta Poupança
public abstract class Conta {

    // Atributos
    private String numero;
    private Titular titular;
    protected double saldo;

    // Construtor
    public Conta(String numero, Titular titular, double saldo) {
        this.numero = numero;
        this.titular = titular;
        this.saldo = saldo;
    }

    // Depositar
    public void depositar(double valor) {
        if (valor < 0) {
            throw new IllegalArgumentException("Valor de depósito não pode ser negativo.");
        }
        this.saldo += valor;
        System.out.println("Depósito de R$ " + valor + " realizado com sucesso. Novo saldo: R$ " + this.saldo);
    }

    // Sacar
    public abstract void sacar(double valor);

    // Transferir
    public void transferir(double valor, Conta destino) {
        this.sacar(valor);
        destino.depositar(valor);
    }

    // Consultar Saldo
    public void consultarSaldo() {
        System.out.println("Saldo atual: R$ " + this.saldo);
    }

    // Getters
    public String getNumero() {
        return numero;
    }

    public Titular getTitular() {
        return titular;
    }

    public double getSaldo() {
        return saldo;
    }

    // Ver Conta
    @Override
    public String toString() {
        return "Conta{" +
                "numero='" + numero + '\'' +
                ", titular='" + titular + '\'' +
                ", saldo=" + saldo +
                '}';
    }
    
}
